# =============================================================
# 環境変数テンプレート
# .env.example → コピーして .env にリネームしてください
# =============================================================

# ---- 共通 ----
# スクレイプ対象URL（年度ごとに変更）
TARGET_URL=https://www.kashiwa.u-tokyo.ac.jp/open_campus_2025/

# SQLite DB のパス
DB_PATH=./events.db

# ---- 翻訳 ----
# Gemini API キー
# 取得先: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ---- バックエンド (FastAPI) ----
# 管理者APIキー（/api/admin/* エンドポイントの認証）
# 強力なランダム文字列を設定してください
# 例: openssl rand -hex 32
ADMIN_API_KEY=change-me-to-a-strong-random-string

# フロントエンドからのCORSを許可するオリジン（カンマ区切り）
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ---- フロントエンド (Vite) ----
# バックエンドAPIのURL（本番はRender.comのURL）
VITE_API_URL=http://localhost:8000

# ---- GitHub Actions Secrets に設定する変数 ----
# GEMINI_API_KEY   : 上記と同じ
# ADMIN_API_KEY    : 上記と同じ
# RENDER_ADMIN_URL : Render.comのバックエンドURL（例: https://kashiwa-api.onrender.com）
# RENDER_DB_DOWNLOAD_URL : DBダウンロードURL（任意）
